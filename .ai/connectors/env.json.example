{
  "grafana": {
    "environments": {
      "test": {
        "lokiUrl": "https://loki.test.example.com",
        "username": "YOUR_GRAFANA_USERNAME",
        "password": "YOUR_GRAFANA_PASSWORD_OR_TOKEN"
      },
      "uat": {
        "lokiUrl": "https://loki.uat.example.com",
        "username": "YOUR_GRAFANA_USERNAME",
        "password": "YOUR_GRAFANA_PASSWORD_OR_TOKEN"
      },
      "prod": {
        "lokiUrl": "https://loki.prod.example.com",
        "username": "YOUR_GRAFANA_USERNAME",
        "password": "YOUR_GRAFANA_PASSWORD_OR_TOKEN"
      }
    }
  },
  "gitlab": {
    "baseUrl": "https://gitlab.example.com",
    "token": "YOUR_GITLAB_PAT"
  },
  "jira": {
    "baseUrl": "https://yourorg.atlassian.net",
    "email": "your.email@example.com",
    "token": "YOUR_JIRA_API_TOKEN",
    "defaultProject": "YOUR_PROJECT_KEY"
  },
  "mongodb": {
    "environments": {
      "test": {
        "uri": "mongodb://user:password@test-mongo.example.com:27017/dbname?authSource=admin"
      },
      "uat": {
        "uri": "mongodb://user:password@uat-mongo.example.com:27017/dbname?authSource=admin"
      }
    }
  }
}
